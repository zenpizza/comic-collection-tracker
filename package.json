{
  "name": "comic-collection-tracker",
  "version": "1.0.0",
  "description": "Track your comic book collection and find missing issues",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "server:dev": "NODE_ENV=development node -r dotenv/config server.js dotenv_config_path=.env.development",
    "start": "npm run build && npm run server",
    "dev:full": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "dev:db": "docker-compose up -d",
    "dev:db:stop": "docker-compose down",
    "dev:db:logs": "docker-compose logs -f mongodb",
    "dev:db:reset": "docker-compose down -v && docker-compose up -d",
    "dev:verify": "node scripts/verify-dev-setup.js",
    "env": "node scripts/show-environment.js",
    "vercel-build": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mongodb": "node scripts/test-mongodb.js",
    "test:mongodb-simple": "node scripts/test-mongodb-simple.js",
    "test:storage": "node scripts/test-storage-operations.js",
    "test:api": "node scripts/test-api-endpoints.js",
    "test:api-simple": "node scripts/test-api-simple.js",
    "test:blob-cleanup": "node scripts/test-blob-cleanup.js",
    "test:blob-integration": "node scripts/test-app-blob-cleanup.js",
    "test:cover-replacement": "node scripts/test-cover-replacement.js",
    "test:cover-replacement-comicvine": "node scripts/test-cover-replacement-comicvine.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.955.0",
    "@aws-sdk/client-s3": "^3.955.0",
    "@clerk/backend": "^3.2.9",
    "@clerk/react": "^6.3.0",
    "busboy": "^1.6.0",
    "commander": "^11.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "mongodb": "^6.3.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.2",
    "fast-check": "^4.5.2",
    "mongodb-memory-server": "^11.2.0",
    "vite": "^7.1.10",
    "vitest": "^4.0.16"
  }
}
