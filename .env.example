# Comic Vine API Configuration
VITE_COMICVINE_API_KEY=your_comic_vine_api_key_here

# Get your API key from: https://comicvine.gamespot.com/api/
# For production, set COMICVINE_API_KEY in Vercel environment variables
# Instructions:
# 1. Create a Comic Vine account
# 2. Go to https://comicvine.gamespot.com/api/
# 3. Generate an API key
# 4. Copy the key and replace 'your_comic_vine_api_key_here' above

# AWS S3 Configuration (for image storage)
# These are set in Vercel environment variables for preview/production
# For local development, images fall back to MongoDB if S3 is not configured
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_S3_KEY_PREFIX=development
AWS_S3_PUBLIC_BASE_URL=https://your-cloudfront-domain.cloudfront.net
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# Optional: for CloudFront cache invalidation
AWS_CLOUDFRONT_DISTRIBUTION_ID=your_distribution_id