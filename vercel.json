{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/comics.js": {
      "maxDuration": 30
    },
    "api/cover-proxy.js": {
      "maxDuration": 30
    },
    "api/cover-search.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}